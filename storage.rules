rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /payment_screenshots/{allPaths=**} {
      allow read: if request.auth != null; // Only authenticated users (admins usually)
      allow write: if request.auth != null; // Any authenticated user can upload
    }
    match /submissions/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teacher', 'super_admin']
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /courses/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teacher'];
    }
  }
}
